def migrate_layer9_sessions(old_path: str, new_path: str) -> bool:
    """Layer 9: Update cwd in ~/.claude/sessions/*.json for stale refs."""
    log("Layer 9: Session files")
    sessions_dir = os.path.expanduser("~/.claude/sessions")
    if not os.path.isdir(sessions_dir):
        log("  No sessions dir (OK)")
        return True

    for fname in os.listdir(sessions_dir):
        if not fname.endswith(".json"):
            continue
        fpath = os.path.join(sessions_dir, fname)
        try:
            with open(fpath, "r") as f:
                data = json.load(f)
        except (json.JSONDecodeError, OSError):
            continue

        cwd = data.get("cwd", "")
        if cwd != old_path and not cwd.startswith(old_path + "/"):
            continue

        # Check if PID is dead (only update stale sessions)
        pid = data.get("pid")
        alive = False
        if pid is not None:
            try:
                os.kill(pid, 0)
                alive = True
            except (ProcessLookupError, PermissionError):
                pass

        if alive:
            log(f"  Skipping {fname} (session still active, pid={pid})")
            continue

        new_cwd = new_path + cwd[len(old_path) :]
        data["cwd"] = new_cwd

        if not dry_run:
            backup_file(fpath)
            atomic_write(fpath, json.dumps(data, indent=2) + "\n")
            modified_files.append(fpath)

        add_change(9, fpath, f"Updated cwd in {fname}")

    return True


# ── Post-migration verification ───────────────────────────────────────
def verify_no_residual(old_path: str, new_path: str, old_encoded: str, new_encoded: str) -> None:
    """Check modified files for any remaining old path references."""
    log("Verification: checking for residual old paths...")
    residual_count = 0
    for fpath in modified_files:
        if not os.path.isfile(fpath):
            continue
        try:
            with open(fpath, "r", encoding="utf-8", errors="surrogateescape") as f:
                content = f.read()
            for needle, replacement in ((old_path, new_path), (old_encoded, new_encoded)):
                hits = content.count(needle)
                # Subtract occurrences that are part of the replacement string
                # (e.g., /home/user/app inside /home/user/app-v2)
                if needle in replacement:
                    # Each replacement occurrence contributes K needle matches
                    k = replacement.count(needle)
                    hits -= content.count(replacement) * k
                if hits > 0:
                    warn(f"Residual: {hits} occurrence(s) of '{needle}' in {fpath}")
                    residual_count += hits
        except OSError:
            pass

    if residual_count == 0:
        log("  Clean — no residual old path references found")
    else:
        warn(f"{residual_count} total residual old path reference(s) remain")


# ── Report output ─────────────────────────────────────────────────────
def emit_json_report(exit_code: int) -> None:
    report = {
        "success": exit_code in (EXIT_OK, EXIT_NOOP),
        "exitCode": exit_code,
        "version": VERSION,
        "changes": changes,
        "manifest": manifest,
        "warnings": warnings,
        "errors": errors,
        "backupDir": backup_dir,
        "dryRun": dry_run,
    }
    print(json.dumps(report, indent=2))


def emit_human_report(exit_code: int, new_path: str) -> None:
    print("", file=sys.stderr)
    print("════════════════════════════════════════════", file=sys.stderr)
    if dry_run:
        log(f"DRY RUN: {len(changes)} change(s) would be made")
    elif exit_code == EXIT_OK:
        log(f"Done: {len(changes)} change(s) applied")
    elif exit_code == EXIT_ROLLBACK:
        log("ROLLED BACK after error — see above")
    elif exit_code == EXIT_NOOP:
        log("Nothing to do")

    if warnings:
        log(f"{len(warnings)} warning(s)")
    if backup_dir and not dry_run:
        log(f"Backup: {backup_dir}")
    if exit_code == EXIT_OK and not dry_run:
        if " " in new_path:
            log(f'Verify: cd "{new_path}" && claude --continue')
        else:
            log(f"Verify: cd {new_path} && claude --continue")


