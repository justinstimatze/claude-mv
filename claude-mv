    for fpath in Path(memory_dir).rglob("*"):
        if fpath.is_file():
            count = rewrite_paths_in_file(str(fpath), old_path, new_path, old_encoded, new_encoded)
            if count > 0:
                add_change(4, str(fpath), f"Rewrote {count} refs in {fpath.name}")

    return True


def _splice_history_project(stripped: str, old_path: str, new_path: str) -> tuple[str, bool]:
    """Rewrite only the 'project' field of a history line if it is under old_path.

    Returns (line, changed). Splices the value anchored to the "project" key so an
    identical value in another field (e.g. cwd) is left alone, and uses const_repl
    so backslash sequences in the path aren't interpreted as regex backreferences.
    A line that isn't JSON, or whose project isn't under old_path, returns unchanged.
    """
    try:
        entry = json.loads(stripped)
    except json.JSONDecodeError:
        return stripped, False
    project = entry.get("project", "")
    if not (project == old_path or project.startswith(old_path + "/")):
        return stripped, False
    new_project = new_path + project[len(old_path) :]
    old_fragment = json.dumps(project)
    new_fragment = json.dumps(new_project)
    replacement = '"project": ' + new_fragment
    patched = re.sub(
        r'"project"\s*:\s*' + re.escape(old_fragment),
        const_repl(replacement),
        stripped,
        count=1,
    )
    return patched, True


def migrate_layer5_history(
    old_path: str,
    new_path: str,
    old_encoded: str,
    new_encoded: str,
    copy_mode: bool,
    with_history: bool,
    src_history: str,
    dst_history: str,
) -> bool:
    """Layer 5: Carry the project's history.jsonl lines (JSON-aware, not str.replace).

    Move (copy_mode False): rewrite the "project" field in place on dst_history.
    Copy without --with-history: leave history untouched — rewriting in place would
      strip the preserved source's history association, and the destination has no
      lines for this project to rewrite. This is the safe, non-destructive default.
    Copy with --with-history: DUPLICATE — append rewritten copies of the project's
      source-history lines to dst_history, leaving the originals intact.

    Parsing each line as JSON and only touching the "project" field (never blind
    str.replace) keeps sibling projects sharing a path prefix (/app vs /app-staging)
    safe.
    """
    log("Layer 5: history.jsonl")

    if copy_mode and not with_history:
        log("  Copy mode without --with-history: history.jsonl left untouched")
        return True
    if copy_mode and with_history:
        return _layer5_append_history(old_path, new_path, src_history, dst_history)

    history = dst_history
    if not os.path.isfile(history):
        log("  No history.jsonl (OK)")
        return True

    try:
        with open(history, "r", encoding="utf-8") as f:
            lines = f.readlines()
    except OSError as e:
        warn(f"Cannot read history.jsonl: {e}")
        return True

    new_lines = []
    count = 0
    for line in lines:
        stripped = line.strip()
        if not stripped:
            new_lines.append(line)
            continue
        patched, changed = _splice_history_project(stripped, old_path, new_path)
        if changed:
            new_lines.append(patched + "\n")
            count += 1
        else:
            new_lines.append(line)

    if count > 0:
        if not dry_run:
            backup_file(history)
            old_bytes = sum(len(line.encode("utf-8", "surrogateescape")) for line in lines)
            new_content = "".join(new_lines)
            atomic_write(history, new_content)
            modified_files.append(history)
            manifest.append(
                {
                    "file": history,
                    "refs": count,
                    "bytesBefore": old_bytes,
                    "bytesAfter": len(new_content.encode("utf-8", "surrogateescape")),
                    "linesBefore": len(lines),
                    "linesAfter": len(new_lines),
                }
            )
        add_change(5, history, f"Rewrote {count} project entries")
    return True


def _layer5_append_history(
    old_path: str, new_path: str, src_history: str, dst_history: str
) -> bool:
    """Copy-mode --with-history: append the source project's history lines to dst.

    Purely additive: originals (in src_history, possibly == dst_history same-account)
    are never modified. No manifest entry is recorded — the manifest's line-count
    invariant is for in-place rewrites, and an append intentionally grows the file.
    """
    if not os.path.isfile(src_history):
        log("  No source history.jsonl — nothing to carry (OK)")
        return True
    try:
        with open(src_history, "r", encoding="utf-8") as f:
            src_lines = f.readlines()
    except OSError as e:
        warn(f"Cannot read source history.jsonl: {e}")
        return True

    appended = []
    for line in src_lines:
        stripped = line.strip()
        if not stripped:
            continue
        patched, changed = _splice_history_project(stripped, old_path, new_path)
        if changed:
            appended.append(patched + "\n")

    if not appended:
        log("  No source history lines for this project (OK)")
        return True

    dst_existed = os.path.isfile(dst_history)
    dst_content = ""
    if dst_existed:
        try:
            with open(dst_history, "r", encoding="utf-8") as f:
                dst_content = f.read()
        except OSError as e:
            warn(f"Cannot read destination history.jsonl: {e}")
            return True
    if dst_content and not dst_content.endswith("\n"):
        dst_content += "\n"
    new_content = dst_content + "".join(appended)

    if not dry_run:
        if dst_existed:
            backup_file(dst_history)
        else:
            created_fresh_files.append(dst_history)  # rollback deletes it
        atomic_write(dst_history, new_content)
        # Deliberately NOT added to modified_files: residual-scanning historical
        # display text (which legitimately mentions the old path) would mislead.

    add_change(5, dst_history, f"Appended {len(appended)} history line(s) from source (copy)")
    return True


def migrate_layer6_claude_json(
    old_path: str,
    new_path: str,
    src_claude_json: str,
    dst_claude_json: str,
    inject: bool,
) -> bool:
    """Layer 6: Update project key(s) in .claude.json.

    Same-account (inject False): rename the existing project key(s) in-place in the
    destination .claude.json — original behavior, src_claude_json == dst_claude_json.

    Cross-account (inject True): the destination has no key to rename, so we INJECT —
    read the source .claude.json, pull its project entry (and sub-keys) for old_path,
    rewrite their internal paths, and write them into the destination under the new
    key(s). A rename-only pass would no-op and the migrated project would never get a
    .claude.json entry.
    """
    log("Layer 6: .claude.json")

    # Path-boundary-aware replacement for JSON values: only replace old_path when
    # followed by / (subpath), " (end of JSON string), or end of string. This
    # prevents /app from corrupting /app-staging.
    path_pattern = re.compile(re.escape(old_path) + r'(?=[/"]|$)')

    if inject:
        return _layer6_inject(old_path, new_path, src_claude_json, dst_claude_json, path_pattern)

    claude_json = dst_claude_json
    if not os.path.isfile(claude_json):
        log("  No .claude.json (OK)")
        return True

    try:
        with open(claude_json, "r") as f:
            data = json.load(f)
    except (json.JSONDecodeError, OSError) as e:
        err(f"Cannot read .claude.json: {e}")
        return False

    projects = data.get("projects", {})
    changed = False

    # Rename exact key and rewrite paths in values
    if old_path in projects:
        val_str = json.dumps(projects.pop(old_path))
        val_str = path_pattern.sub(lambda m: new_path, val_str)
        projects[new_path] = json.loads(val_str)
        changed = True

    # Rename sub-project keys (e.g. /old/path/subdir)
    for key in list(projects.keys()):
        if key.startswith(old_path + "/"):
            new_key = new_path + key[len(old_path) :]
            val_str = json.dumps(projects.pop(key))
            val_str = path_pattern.sub(lambda m: new_path, val_str)
            projects[new_key] = json.loads(val_str)
            changed = True

    if not changed:
        log("  No matching project key")
        return True

    data["projects"] = projects

    if not dry_run:
        backup_file(claude_json)
        output = json.dumps(data, indent=2) + "\n"
        atomic_write(claude_json, output)
        modified_files.append(claude_json)

        if not validate_json(claude_json):
            err(".claude.json corrupted after rewrite!")
            return False

    add_change(6, claude_json, "Updated project key(s)")
    return True


def _layer6_inject(
    old_path: str,
    new_path: str,
    src_claude_json: str,
    dst_claude_json: str,
    path_pattern: re.Pattern[str],
) -> bool:
    """Cross-account branch of Layer 6: inject the source project entry into dst."""
    if not os.path.isfile(src_claude_json):
        log("  No source .claude.json — nothing to inject (OK)")
        return True
    try:
        with open(src_claude_json, "r") as f:
            src_data = json.load(f)
    except (json.JSONDecodeError, OSError) as e:
        err(f"Cannot read source .claude.json: {e}")
        return False

    src_projects = src_data.get("projects", {})
    entries: list[tuple[str, object]] = []
    for key, val in src_projects.items():
        if key == old_path or key.startswith(old_path + "/"):
            new_key = new_path + key[len(old_path) :]
            entries.append((new_key, val))

    if not entries:
        log("  No matching project key in source .claude.json (OK)")
        return True

    # Load destination (may be absent on a fresh account → start minimal).
    dst_existed = os.path.isfile(dst_claude_json)
    if dst_existed:
        try:
            with open(dst_claude_json, "r") as f:
                dst_data = json.load(f)
        except (json.JSONDecodeError, OSError) as e:
            err(f"Cannot read destination .claude.json: {e}")
            return False
    else:
        dst_data = {}

    dst_projects = dst_data.get("projects", {})
    for new_key, val in entries:
        if new_key in dst_projects:
            log(f"  Overwriting existing destination key {new_key}")
        val_str = path_pattern.sub(lambda m: new_path, json.dumps(val))
        dst_projects[new_key] = json.loads(val_str)
    dst_data["projects"] = dst_projects

    if not dry_run:
        if dst_existed:
            backup_file(dst_claude_json)
        else:
            created_fresh_files.append(dst_claude_json)  # rollback deletes it
        atomic_write(dst_claude_json, json.dumps(dst_data, indent=2) + "\n")
        modified_files.append(dst_claude_json)
        if not validate_json(dst_claude_json):
            err(".claude.json corrupted after inject!")
            return False

    add_change(6, dst_claude_json, f"Injected {len(entries)} project key(s) from source")
    return True


