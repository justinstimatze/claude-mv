# MAIN
# ═══════════════════════════════════════════════════════════════════════


def main() -> None:
    global json_mode, dry_run

    # Pre-scan flags so die() reports correctly even on early failures
    json_mode = "--json" in sys.argv
    dry_run = "--dry-run" in sys.argv

    parser = argparse.ArgumentParser(
        prog="claude-mv",
        description="Move a Claude Code project's internal state to match a new directory location.",
        epilog="The repo/directory itself must already be at new-path (use mv/cp first, then claude-mv).",
    )
    parser.add_argument(
        "paths",
        nargs="+",
        metavar="PATH",
        help="<old-path> <new-path>, or just <new-path> for auto-detect",
    )
    parser.add_argument(
        "--dry-run", action="store_true", help="Show what would change without modifying anything"
    )
    parser.add_argument(
        "--json", action="store_true", help="Machine-readable JSON output on stdout"
    )
    parser.add_argument(
        "--force", action="store_true", help="Proceed even if active sessions detected"
    )
    parser.add_argument(
        "--copy",
        action="store_true",
        help="Copy instead of move: leave the source project state intact",
    )
    parser.add_argument(
        "--from-home",
        metavar="SRC_HOME",
        help="Read source state from another account's home (e.g. /home/alice). Implies --copy.",
    )
    parser.add_argument(
        "--with-history",
        action="store_true",
        help="Copy mode only: also carry the project's history.jsonl lines to the new location.",
    )
    parser.add_argument("--version", action="version", version=f"claude-mv {VERSION}")
    args = parser.parse_args()

    json_mode = args.json
    dry_run = args.dry_run
    cross_account = bool(args.from_home)
    copy_mode = args.copy or cross_account
    with_history = args.with_history
    if with_history and not copy_mode:
        die("--with-history only applies to copy mode (use with --copy or --from-home)")

    # ── Resolve paths ─────────────────────────────────────────────────
    if len(args.paths) == 2:
        old_path = os.path.realpath(args.paths[0])
        new_path = os.path.realpath(args.paths[1])
    elif len(args.paths) == 1:
        if cross_account:
            die("--from-home requires both paths: claude-mv --from-home <src_home> <old> <new>")
        new_path = os.path.realpath(args.paths[0])
        log(f"Auto-detecting old path for: {new_path}")
        detected = auto_detect_old_path(new_path)
        if detected is None:
            die("Could not auto-detect old path. Provide both: claude-mv <old> <new>")
        old_path = os.path.realpath(detected)
        log(f"Detected: {old_path}")
    else:
        die("Expected 1 or 2 path arguments")

    # Guard against catastrophically short paths — replacing "/" would
    # corrupt every forward slash in every file.
    for label, p in [("Old", old_path), ("New", new_path)]:
        parts = [x for x in p.split("/") if x]
        if len(parts) < 2:
            die(f"{label} path too short to be a project directory: {p}")

    if old_path == new_path:
        log("Old and new paths are identical — nothing to do")
        if json_mode:
            emit_json_report(EXIT_NOOP)
        sys.exit(EXIT_NOOP)

    # Guard against ancestor/descendant moves — str.replace would corrupt
    # entries that already reference the longer path (double-suffix bug).
    if new_path.startswith(old_path + "/"):
        die(
            f"New path is inside old path ({new_path} ⊂ {old_path}). "
            f"Ancestor-to-descendant moves are not supported."
        )
    if old_path.startswith(new_path + "/"):
        die(
            f"Old path is inside new path ({old_path} ⊂ {new_path}). "
            f"Descendant-to-ancestor moves are not supported."
        )

    if not os.path.isdir(new_path):
        die(f"New path does not exist: {new_path} (move the repo first, then run claude-mv)")

    claude_dir = os.path.expanduser("~/.claude")
    if not os.path.isdir(claude_dir):
        die("No ~/.claude directory found")

    # Destination is always the current account. Source differs only cross-account.
    dst_claude_dir = claude_dir
    dst_claude_json = os.path.expanduser("~/.claude.json")
    dst_history = os.path.expanduser("~/.claude/history.jsonl")
    if cross_account:
        src_home = os.path.realpath(args.from_home)
        src_claude_dir = os.path.join(src_home, ".claude")
        src_claude_json = os.path.join(src_home, ".claude.json")
        src_history = os.path.join(src_claude_dir, "history.jsonl")
        if not os.path.isdir(src_claude_dir):
            die(f"Source home has no .claude directory: {src_claude_dir}")
    else:
        src_claude_dir = dst_claude_dir
        src_claude_json = dst_claude_json
        src_history = dst_history

    old_encoded = encode_path(old_path)
    new_encoded = encode_path(new_path)
    new_project_dir = os.path.join(claude_dir, "projects", new_encoded)

    log(f"Old path:    {old_path}")
    log(f"New path:    {new_path}")
    log(f"Old encoded: {old_encoded}")
    log(f"New encoded: {new_encoded}")
    log(f"Dry run:     {dry_run}")
    log("")

    # ── Encoding collision check ──────────────────────────────────────
    if check_encoding_collision(old_path, new_path, old_encoded, new_encoded):
        die(f"Encoding collision detected for {new_encoded}. Aborting to prevent data loss.")

    # ── Prefix collision check ────────────────────────────────────────
    # Warn if old_path is a prefix of any sibling project (str.replace in
    # per-project JSONL files is safe, but ~/.claude.json values could be
    # affected if they reference sibling paths).
    claude_json_path = os.path.expanduser("~/.claude.json")
    if os.path.isfile(claude_json_path):
        try:
            with open(claude_json_path, "r") as f:
                cj = json.load(f)
            for key in cj.get("projects", {}):
                if key != old_path and key.startswith(old_path + "/"):
                    # Sub-project — this is expected and handled correctly
                    pass
                elif key != old_path and key.startswith(old_path):
                    warn(
                        f"Sibling project '{key}' shares prefix with old path '{old_path}'. "
                        f"Layer 6 value rewriting may affect it — verify after migration."
                    )
        except (json.JSONDecodeError, OSError):
            pass

    # ── Active session check ──────────────────────────────────────────
    active = check_active_sessions(old_path, args.force)
    if active and not args.force:
        if json_mode:
            emit_json_report(EXIT_ACTIVE_SESSION)
        sys.exit(EXIT_ACTIVE_SESSION)

    # Cross-account: also warn about (unverifiable) live sessions in the source
    # account. check_active_sessions above only sees the destination account.
    if cross_account:
        warn_source_sessions(src_claude_dir, old_path)

    # ── Readability preflight ─────────────────────────────────────────
    # Fail up front if any file we must READ is unreadable by the current uid.
    # Proceeding would silently leave stale paths (rewrite helpers return 0 on
    # read failure). Not bypassable by --force: an unreadable file cannot be
    # migrated, only mis-migrated.
    preflight_old_dir = os.path.join(src_claude_dir, "projects", old_encoded)
    # Check the history file Layer 5 will actually read: src under --with-history,
    # dst on a move, and none when copy mode leaves history untouched.
    if copy_mode and not with_history:
        preflight_history = ""
    elif copy_mode and with_history:
        preflight_history = src_history
    else:
        preflight_history = dst_history
    unreadable = preflight_readability(
        preflight_old_dir, new_path, src_claude_json, preflight_history
    )
    if unreadable:
        by_category: dict[str, list[str]] = {}
        for fpath, category in unreadable:
            err(f"Unreadable by current user [{category}]: {fpath}")
            by_category.setdefault(category, []).append(fpath)

        # Per-category remediation. ACL-mask categories steer to setfacl (chmod
        # o+r is a no-op against a named-user ACL entry); ownership/mode steer to
        # the owning account. -R targets the project dir, which holds the bulk;
        # any stray file listed above (history.jsonl, .claude.json) needs the
        # same treatment applied to it directly.
        blocks: list[str] = []
        if "mask" in by_category:
            blocks.append(
                f"{len(by_category['mask'])} file(s): CONFIRMED ACL mask clamp (getfacl shows "
                f"read stripped by the mask). chmod o+r will NOT fix this. As the owning "
                f"account run:\n    setfacl -R -m mask::rwx {preflight_old_dir}\n"
                f"(or: chmod -R g+rX {preflight_old_dir} — chmod's group bits set the mask "
                f"when an ACL is present)."
            )
        if "mask?" in by_category:
            blocks.append(
                f"{len(by_category['mask?'])} file(s): LIKELY an ACL mask clamp (mode advertises "
                f"group/other read but access is denied; getfacl unavailable to confirm — "
                f"install the 'acl' package). As the owning account run:\n"
                f"    setfacl -R -m mask::rwx {preflight_old_dir}\n"
                f"(or: chmod -R g+rX {preflight_old_dir})."
            )
        if "ownership" in by_category:
            blocks.append(
                f"{len(by_category['ownership'])} file(s): owned by another account. As that "
                f"account run:\n    chmod -R u+rX {preflight_old_dir}\n"
                f"or grant your account read via ACL:\n"
                f"    setfacl -R -m u:$(id -un):rX {preflight_old_dir}"
            )
        if "mode" in by_category:
            blocks.append(
                f"{len(by_category['mode'])} file(s): you own these but the mode is too "
                f"restrictive. Run:\n    chmod -R u+rX {preflight_old_dir}"
            )
        die(
            f"{len(unreadable)} file(s) claude-mv must read are unreadable — aborting to "
            f"avoid a silent partial migration.\n" + "\n".join(blocks)
        )

    # ── Pre-flight size estimate ─────────────────────────────────────
    total_bytes = 0
    history_path = os.path.expanduser("~/.claude/history.jsonl")
    for check_path in [history_path]:
        if os.path.isfile(check_path):
            total_bytes += os.path.getsize(check_path)
    # The project bytes live under the SOURCE claude dir (== dst same-account).
    old_project_dir_pre = os.path.join(src_claude_dir, "projects", old_encoded)
    if os.path.isdir(old_project_dir_pre):
        for root, _, fnames in os.walk(old_project_dir_pre):
            for fn in fnames:
                total_bytes += os.path.getsize(os.path.join(root, fn))
    if total_bytes > 100_000_000:  # 100 MB
        warn(
            f"Large dataset ({total_bytes // 1_000_000} MB) — migration may use significant memory"
        )

    # ── Create backup ─────────────────────────────────────────────────
    if not dry_run:
        create_backup()

    # ── Install signal handlers for clean rollback ────────────────────
    signal.signal(signal.SIGINT, _signal_handler)
    signal.signal(signal.SIGTERM, _signal_handler)

    # ── Run all layers ────────────────────────────────────────────────
    global migration_in_progress
    old_project_dir = os.path.join(dst_claude_dir, "projects", old_encoded)
    src_project_dir = os.path.join(src_claude_dir, "projects", old_encoded)

    # After layer 1, files live in new_project_dir. In dry-run nothing is moved/copied,
    # so they remain at the source (old_project_dir same-account, src_project_dir
    # cross-account); pointing layers 2-4 there keeps dry-run previews accurate.
    def effective_project_dir() -> str:
        if os.path.isdir(new_project_dir):
            return new_project_dir
        if os.path.isdir(old_project_dir):
            return old_project_dir
        if os.path.isdir(src_project_dir):
            return src_project_dir
        return new_project_dir  # fallback

    migration_in_progress = True
    layer_ok = True
    layers: list[tuple[int, Callable[[], bool]]] = [
        (
            1,
            lambda: migrate_layer1_project_dir(
                old_encoded, new_encoded, src_claude_dir, dst_claude_dir, copy_mode
            ),
        ),
        (
            2,
            lambda: migrate_layer2_jsonl(
                effective_project_dir(), old_path, new_path, old_encoded, new_encoded
            ),
        ),
        (
            3,
            lambda: migrate_layer3_subagents(
                effective_project_dir(), old_path, new_path, old_encoded, new_encoded
            ),
        ),
        (
            4,
            lambda: migrate_layer4_memory(
                effective_project_dir(), old_path, new_path, old_encoded, new_encoded
            ),
        ),
        (
            5,
            lambda: migrate_layer5_history(
                old_path,
                new_path,
                old_encoded,
                new_encoded,
                copy_mode,
                with_history,
                src_history,
                dst_history,
            ),
        ),
        (
            6,
            lambda: migrate_layer6_claude_json(
                old_path, new_path, src_claude_json, dst_claude_json, cross_account
            ),
        ),
        (7, lambda: migrate_layer7_mcp_json(new_path, old_path, old_encoded, new_encoded)),
        (8, lambda: migrate_layer8_settings(new_path, old_path, old_encoded, new_encoded)),
        (9, lambda: migrate_layer9_sessions(old_path, new_path)),
    ]
    for layer_num, layer_fn in layers:
        try:
            if not layer_fn():
                layer_ok = False
                break
        except Exception as e:
            err(f"Layer {layer_num} failed: {e}")
            traceback.print_exc(file=sys.stderr)
            layer_ok = False
            break
    migration_in_progress = False

    # ── Handle failure ────────────────────────────────────────────────
    if not layer_ok and not dry_run:
        rollback()
        if json_mode:
            emit_json_report(EXIT_ROLLBACK)
        else:
            emit_human_report(EXIT_ROLLBACK, new_path)
        sys.exit(EXIT_ROLLBACK)

    # ── Post-migration verification ───────────────────────────────────
    if not dry_run and changes:
        verify_no_residual(old_path, new_path, old_encoded, new_encoded)

    # ── Report ────────────────────────────────────────────────────────
    exit_code = EXIT_OK if changes else EXIT_NOOP

    # Check for old directory before emitting report so it's included in JSON. Under
    # copy mode the source is meant to remain, so this is informational, not a warning.
    if os.path.isdir(old_path) and not dry_run and exit_code == EXIT_OK:
        if copy_mode:
            log(f"Source preserved at {old_path} (copy mode — remove it yourself if desired)")
        else:
            warn(f"Old directory still exists at {old_path}")

    if json_mode:
        emit_json_report(exit_code)
    else:
        emit_human_report(exit_code, new_path)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
